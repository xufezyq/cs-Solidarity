{
  "enabled": {
    "description": "启用灾害预警插件",
    "type": "bool",
    "hint": "内置的插件总开关",
    "default": true
  },
  "admin_users": {
    "description": "插件管理员列表",
    "type": "list",
    "hint": "输入用户ID（QQ号等）。这些用户拥有管理插件的高级权限（如查看日志、修改配置等）。AstrBot的全站管理员默认拥有权限，无需在此重复添加。",
    "default": null
  },
  "target_sessions": {
    "description": "推送会话列表",
    "type": "list",
    "hint": "请输入完整的 UMO，可通过 /sid 指令快捷获取。格式: {platform_name}:{message_type}:{session_id}。{platform_name} 就是你在 WebUI 中的 机器人 一栏自定义的机器人名称。{message_type} 可选参数为“GroupMessage”和“FriendMessage”。例如 aiocqhttp:GroupMessage:123456 或 aiocqhttp:FriendMessage:123456",
    "default": []
  },
  "offline_notification_sessions": {
    "description": "离线通知接收会话列表",
    "type": "list",
    "hint": "用于接收数据源离线通知，留空时将沿用推送会话列表。如果你配置了多会话的推送，建议单独配置一个运维群，避免打扰业务群。",
    "default": []
  },
  "display_timezone": {
    "description": "默认显示时区",
    "type": "string",
    "hint": "所有灾害预警消息中时间显示的默认时区。格式示例：UTC+8, UTC-5, Asia/Shanghai",
    "default": "UTC+8"
  },
