          },
          "japan_jma_earthquake": {
            "description": "日本気象庁（JMA）：地震情報",
            "type": "bool",
            "default": true,
            "hint": "通过P2P地震情報 WebSocket接收日本气象厅地震情报（code:551）"
          },
          "japan_jma_tsunami": {
            "description": "日本気象庁：津波予報",
            "type": "bool",
