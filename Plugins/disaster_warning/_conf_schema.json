          },
          "china_tsunami": {
            "description": "自然资源部海啸预警中心：海啸预警信息",
            "type": "bool",
            "default": true,
            "hint": "通过FAN Studio WebSocket接收自然资源部海啸预警中心海啸预警信息"
          }
        }
      },
      "p2p_earthquake": {
        "description": "P2P地震情報 WebSocket 数据源",
        "type": "object",
        "hint": "P2P数据源总开关",
        "items": {
          "enabled": {
            "description": "启用P2P地震情報数据源",
            "type": "bool",
            "default": true
